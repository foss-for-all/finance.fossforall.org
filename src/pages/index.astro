---
import 'bulma/css/bulma.min.css';
import FinanceReportApp from '../components/finance/FinanceReportApp';
import Layout from '../layouts/Layout.astro';
import { buildReportCatalog } from '../lib/finance/catalog';
import '../styles/finance-report.css';

const dataMap = import.meta.glob('../data/**/*.json', {
	eager: true,
	import: 'default'
}) as Record<string, unknown>;

const catalog = buildReportCatalog(dataMap);
---

<Layout title="Finance Reports">
	<div class="finance-layout">
		<FinanceReportApp client:load catalog={catalog} dataMap={dataMap} />
	</div>
</Layout>
